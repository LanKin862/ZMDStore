{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZMD Store Desktop",
  "version": "1.2.0",
  "identifier": "com.zmdstore.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZMD Store Desktop",
        "width": 1380,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "../auto_click.py",
      "../tauri_bridge.py",
      "../item",
      "../region",
      "../public"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
